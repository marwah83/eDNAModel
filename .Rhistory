expect_true("Name" %in% colnames(sample_data(physeq_one)), info = "Column 'Name' missing from sample_data")
# Run the model
out <- FitModel_gllvm(
phyloseq = physeq_one,
site_col = "Name",
abundance_rhs = (1 | Samplingmonth / OTU) + (1 | OTU),
occupancy_covars = "Samplingmonth",
abundance_family = "poisson",
