# Load testthat
library(testthat)
library(phyloseq)
# Only run this test if the required packages are installed
test_that("FitModel_gllvm runs and returns expected structure", {
skip_if_not_installed("glmmTMB")
skip_if_not_installed("gllvm")
skip_if_not_installed("phyloseq")
skip_if_not_installed("reshape2")
# Load example phyloseq data
data("GlobalPatterns")
# Subset to keep test light and fast
physeq_test <- prune_taxa(taxa_sums(GlobalPatterns) > 50, GlobalPatterns)
physeq_test <- prune_samples(sample_sums(physeq_test) > 1000, physeq_test)
physeq_test <- phyloseq::subset_samples(physeq_test, !is.na(SampleType))
# Create fake site_col (because gllvm needs grouping)
sample_data(physeq_test)$SiteGroup <- factor(rep(c("A", "B"), length.out = nsamples(physeq_test)))
# Run model with small number of iterations
result <- FitModel_gllvm(
phyloseq = physeq_test,
site_col = "SiteGroup",
abundance_rhs = ~ SampleType,
occupancy_covars = "SampleType",
n_iter = 3,
burn_in = 1,
min_species_sum = 100
)
# Check return structure
expect_type(result, "list")
expect_true(all(c("summary", "psi_list", "lambda_list", "p_detect_list",
"occupancy_models", "abundance_models",
"lv_sites", "lv_species",
"mean_lv_sites", "mean_lv_species") %in% names(result)))
# Check that outputs are not empty
expect_gt(nrow(result$summary), 0)
expect_gt(length(result$psi_list), 0)
expect_gt(nrow(result$lv_sites), 0)
expect_gt(nrow(result$lv_species), 0)
})
test_that("FitModel_gllvm runs and returns expected structure", {
