expect_true(exists("physeq_one"), info = "physeq_one is not available")
# Ensure necessary column exists
expect_true("Name" %in% colnames(sample_data(physeq_one)), info = "Column 'Name' missing from sample_data")
# Run the model
out <- FitModel_gllvm(
